FROM node:22-alpine AS builder

# Install pnpm
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable

WORKDIR /app

# Copy workspace config and package.json files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

# Install dependencies specifically for web
RUN pnpm install --filter @jejakhijau/web... --frozen-lockfile

# Copy source code
COPY apps/web ./apps/web
COPY packages/shared ./packages/shared

# Inject API URL during build time
ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

# Build Web App
RUN pnpm --filter @jejakhijau/web build

# Stage 2: Serve with Nginx
FROM nginx:alpine

# Copy built assets to Nginx
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html

# Copy custom Nginx configuration template for dynamic PORT binding
COPY nginx.conf.template /etc/nginx/templates/default.conf.template

# Cloud Run defaults to 8080 if PORT is not set
ENV PORT=8080
EXPOSE $PORT

CMD ["nginx", "-g", "daemon off;"]
